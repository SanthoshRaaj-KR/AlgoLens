# ── Go backend (go/.env) ─────────────────────────────────────────────────────

# Postgres connection string (required)
# Supabase: Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Restrict CORS to your frontend origin in production.
# Leave unset for local dev (defaults to "*").
CORS_ORIGIN=https://your-frontend.example.com

# ── Python sidecar ────────────────────────────────────────────────────────────

# Anthropic API key (required for agentic simulation mode)
# Get it at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Go internal probe server — do not change unless you move the internal port
GO_INTERNAL_URL=http://localhost:8081

# ── Frontend (frontend/.env.local) ────────────────────────────────────────────

# Go API base URL (default: http://localhost:8080)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Python sidecar base URL (default: http://localhost:8001)
NEXT_PUBLIC_PY_URL=http://localhost:8001
